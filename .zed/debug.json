// see: https://zed.dev/docs/debugger
[
  {
    "label": "pyKorf: Web Server",
    "adapter": "Debugpy",
    "request": "launch",
    "module": "pykorf.cli",
    "cwd": "$ZED_WORKTREE_ROOT",
    "env": {
      "FLASK_APP": "pykorf.app:create_app",
      "FLASK_DEBUG": "0"
    },
    "args": ["--debug", "--port", "8000"],
    "autoReload": {
      "enable": false
    },
    "jinja": true,
    "justMyCode": true
  },
  {
    "label": "pyKorf: Run Tests",
    "adapter": "Debugpy",
    "request": "launch",
    "module": "pytest",
    "cwd": "$ZED_WORKTREE_ROOT",
    "args": ["tests/", "-v"],
    "justMyCode": false,
  },
]

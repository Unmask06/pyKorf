# ── Python build / runtime ──────────────────────────────────
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/
*.egg

# ── Virtual environments ───────────────────────────────────
.venv/

# ── Frontend (built by distribute.bat; not checked in) ─────
pykorf/app/frontend/dist/
pykorf/app/frontend/node_modules/

# ── Tool caches ───────────────────────────────────────────
.mypy_cache/
.pytest_cache/
.ruff_cache/
.cache/

# ── IDE / editor ──────────────────────────────────────────
*.code-workspace

# ── Generated docs site (rebuild with `mkdocs build`) ────
site/

# ── Generated visualization & scratch files ───────────────
network.html
network_data.json
trail.html
trail_vis.json
lib/
nul

# ── Binary / large non-source files ──────────────────────
*.xlsx
*.xlsx*
*.pdf
*.png

# ── Lock file (large, not needed for AI context) ─────────
uv.lock

# ── Notebook outputs & scratch notebooks ─────────────────
korf_automation.ipynb
trail.ipynb

# ── Example outputs (regenerated by running examples) ────
examples/output/
examples/examples/
*.log

*.kilo/
*.qwen/

# ── Local / personal settings ─────────────────────────────
*.local*
.local/
settings.local.jsonnul
*.opencode
